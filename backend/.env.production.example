############################################
#  Backend Production Environment Template  #
#  用于正式/商业化部署，请按实际情况填写   #
############################################

# ========== Application ==========
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
FRONTEND_DIR=/var/www/massmail/frontend/dist
SERVER_PUBLIC_ORIGIN=https://app.example.com

# 与前端实际访问来源保持一致；同域反代时也建议显式填写，便于排查
CORS_ORIGINS=https://app.example.com
ALLOWED_ORIGINS=https://app.example.com

# ========== Database (MySQL) ==========
DB_HOST=43.160.250.204          # 或你的数据库服务器内网 IP / 域名
DB_PORT=3306
DB_USER=massmail                # 建议为本系统单独创建账号
DB_PASSWORD=CHANGE_ME_STRONG    # 使用强密码，不要使用 root 且不要为空
DB_NAME=massmail
# 远程数据库建议开启 TLS
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=true
# DB_SSL_CA=-----BEGIN CERTIFICATE-----...-----END CERTIFICATE-----
# DB_SSL_CERT=-----BEGIN CERTIFICATE-----...-----END CERTIFICATE-----
# DB_SSL_KEY=-----BEGIN PRIVATE KEY-----...-----END PRIVATE KEY-----
# 或使用文件路径（推荐）
# DB_SSL_CA_FILE=/etc/ssl/certs/ca.pem
# DB_SSL_CERT_FILE=/etc/ssl/certs/client-cert.pem
# DB_SSL_KEY_FILE=/etc/ssl/private/client-key.pem

# ========== Redis (BullMQ 队列) ==========
REDIS_HOST=43.160.250.204
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG # 如果 Redis 开启了密码，这里填写
REDIS_URL=redis://:CHANGE_ME_STRONG@43.160.250.204:6379

# 管理员账号（登录后台用）
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=REPLACE_WITH_ARGON2_HASH
# 操作员账号（可选，若设置则 OPERATOR_PASSWORD_HASH 需为 Argon2 哈希）
OPERATOR_USERNAME=operator
OPERATOR_PASSWORD_HASH=

# 至少 32 字符随机字符串，生产环境必须与开发环境不同
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
MSG_ENC_KEY=REPLACE_WITH_32_PLUS_CHAR_SECRET
PROXY_ENC_KEY=REPLACE_WITH_BASE64_SECRET

# ========= Third-party APIs =========
# 正式环境的 Google / 第三方 API Key，不要与开发环境混用
GOOGLE_TRANSLATE_API_KEY=REPLACE_WITH_PROD_API_KEY

# 若你有 2Captcha / 代理等配置，也建议放在这里，例如：
# TWOCAPTCHA_API_KEY=REPLACE_WITH_PROD_2CAPTCHA_KEY
# PROXY_URL=REPLACE_WITH_PROD_PROXY

# 其他与商业化有关的配置，可继续追加，例如租户、计费、日志等。
