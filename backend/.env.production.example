############################################
#  Backend Production Environment Template  #
#  用于正式/商业化部署，请按实际情况填写   #
############################################

# ========== Database (MySQL) ==========
DB_HOST=your-db-host            # 例如: db.internal.yourcompany.com
DB_PORT=3306
DB_USER=massmail_prod           # 建议为本系统单独创建账号
DB_PASSWORD=CHANGE_ME_STRONG    # 使用强密码，不要使用 root 且不要为空
DB_NAME=massmail_prod           # 生产数据库名称，建议与开发隔离

# ========== Redis (BullMQ 队列) ==========
REDIS_HOST=your-redis-host      # 例如: redis.internal.yourcompany.com
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG # 如果 Redis 开启了密码，这里填写

# ========== Application ==========
PORT=3000                       # 后端监听端口，通常由反向代理映射
# CORS 允许的前端来源，逗号分隔（代码读取 CORS_ORIGINS）
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# 管理员账号（登录后台用）
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=REPLACE_WITH_ARGON2_HASH
# 操作员账号（可选，若设置则 OPERATOR_PASSWORD_HASH 需为 Argon2 哈希）
OPERATOR_USERNAME=operator
OPERATOR_PASSWORD_HASH=

# 至少 32 字符随机字符串，生产环境必须与开发环境不同
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET

# ========= Third-party APIs =========
# 正式环境的 Google / 第三方 API Key，不要与开发环境混用
GOOGLE_TRANSLATE_API_KEY=REPLACE_WITH_PROD_API_KEY

# 若你有 2Captcha / 代理等配置，也建议放在这里，例如：
# TWOCAPTCHA_API_KEY=REPLACE_WITH_PROD_2CAPTCHA_KEY
# PROXY_URL=REPLACE_WITH_PROD_PROXY

# 其他与商业化有关的配置，可继续追加，例如租户、计费、日志等。

