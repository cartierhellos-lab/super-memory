## 1️⃣ `device-fingerprint-store.ts`（核心）

👉 解决：**所有随机 → 变成 session 稳定**

```ts
// src/gateway/device-fingerprint-store.ts
import crypto from "crypto";

export type DeviceFingerprint = {
  tlsProfile: string;
  h2Settings: {
    weight: number;
    windowSize: number;
  };
  headerOrderSeed: number;
};

const store = new Map<string, DeviceFingerprint>();

const hashToInt = (input: string) => {
  const hex = crypto.createHash("sha256").update(input).digest("hex");
  return parseInt(hex.slice(0, 8), 16);
};

export const getOrCreateFingerprint = (sessionId: string, platform: "iOS" | "Android"): DeviceFingerprint => {
  if (store.has(sessionId)) return store.get(sessionId)!;

  const seed = hashToInt(sessionId);

  const fingerprint: DeviceFingerprint = {
    tlsProfile: platform === "iOS" ? "cfnetwork" : "okhttp",
    h2Settings: {
      weight: 32 + (seed % 180),
      windowSize: 65535 + (seed % 65535),
    },
    headerOrderSeed: seed,
  };

  store.set(sessionId, fingerprint);
  return fingerprint;
};
```

