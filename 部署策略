## 3️⃣ `behavior-profile.ts`

```ts
// src/behavior/behavior-profile.ts
import crypto from "crypto";

const hash = (input: string) =>
  parseInt(crypto.createHash("sha256").update(input).digest("hex").slice(0, 8), 16);

export type BehaviorProfile = {
  activeHours: [number, number];
  avgIntervalMs: number;
  burstProbability: number;
  replyProbability: number;
};

export const buildBehaviorProfile = (sessionId: string): BehaviorProfile => {
  const seed = hash(sessionId);

  return {
    activeHours: [8 + (seed % 4), 20 + (seed % 3)],
    avgIntervalMs: 4000 + (seed % 20000),
    burstProbability: 0.1 + (seed % 10) / 100,
    replyProbability: 0.2 + (seed % 20) / 100,
  };
};
```

