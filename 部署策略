## 4️⃣ `behavior-engine.ts`

```ts
// src/behavior/behavior-engine.ts
import { buildBehaviorProfile } from "./behavior-profile.js";

export type BehaviorDecision =
  | { type: "send"; text: string }
  | { type: "pause"; delay: number }
  | { type: "simulate_inbound"; text: string };

export const decideBehavior = (sessionId: string): BehaviorDecision => {
  const profile = buildBehaviorProfile(sessionId);
  const hour = new Date().getHours();

  if (hour < profile.activeHours[0] || hour > profile.activeHours[1]) {
    return { type: "pause", delay: 60 * 60 * 1000 };
  }

  if (Math.random() < profile.replyProbability) {
    return { type: "simulate_inbound", text: "ok" };
  }

  if (Math.random() < profile.burstProbability) {
    return { type: "send", text: "hey!" };
  }

  return { type: "pause", delay: profile.avgIntervalMs };
};
```

