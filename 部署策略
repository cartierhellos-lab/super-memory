// ❗禁止任何泄露头（最终保险）
const sanitize = (h: Record<string, string>) =>
  Object.fromEntries(
    Object.entries(h).filter(([k]) => !k.startsWith("x-gw") && !k.startsWith("x-h2") && !k.startsWith("x-ja"))
  );

headers = sanitize(headers);
```

