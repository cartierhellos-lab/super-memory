## 2️⃣ `header-order.ts`（稳定 header 顺序）

```ts
// src/gateway/header-order.ts
import crypto from "crypto";

const h = (v: string) =>
  parseInt(crypto.createHash("md5").update(v).digest("hex").slice(0, 8), 16);

export const buildOrderedHeaders = (
  headers: Record<string, string>,
  seed: number
): Record<string, string> => {
  return Object.fromEntries(
    Object.entries(headers).sort((a, b) => h(a[0] + seed) - h(b[0] + seed))
  );
};
```

