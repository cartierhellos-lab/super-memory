# 本地开发时连接本机后端（复制为 .env.development.local 使用）
# 确保 backend 已启动：cd backend && npm run dev

VITE_API_BASE_URL=http://localhost:3000/api
VITE_SOCKET_BASE_URL=http://localhost:3000
# Vite dev server port (optional)
# VITE_DEV_PORT=8080
# Vite dev proxy target (optional)
# VITE_BACKEND_TARGET=http://127.0.0.1:3000
# Tauri dev: connect local backend explicitly
# VITE_USE_LOCAL_BACKEND=true
